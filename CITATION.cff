cff-version: 1.2.0
title: >-
  A Taxonomy of Real-World Asset Tokenization for
  Blockchain-Based Financial Infrastructure — Dataset
message: >-
  If you use this dataset, please cite both the dataset and
  the accompanying paper.
type: dataset
identifiers:
  - type: url
    value: https://arxiv.org/abs/2606.08534
    description: arXiv preprint
authors:
